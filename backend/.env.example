# Copy this file to `.env` and replace placeholder values.
# PowerShell: Copy-Item .env.example .env

# App
BASE_URL=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/animeapp
PORT=3000
ALLOWED_ORIGINS=

# Security (must be >= 16 chars)
JWT_SECRET=replace_with_long_random_jwt_secret
SESSION_SECRET=replace_with_long_random_session_secret
LOBBY_INVITE_SECRET=replace_with_long_random_lobby_invite_secret
TOKEN_ENCRYPTION_KEY=replace_with_long_random_token_encryption_key
LOBBY_INVITE_TTL=7d
LOBBY_KICK_COOLDOWN_MS=120000
LOBBY_HOST_OFFLINE_TIMEOUT_MS=300000
LOBBY_ZERO_CONNECTED_ROUNDS_TO_KILL=3

# Email (for verify/reset flows)
EMAIL_USER=you@example.com
EMAIL_PASS=replace_with_email_app_password

# MyAnimeList OAuth
MAL_CLIENT_ID=replace_with_mal_client_id
MAL_CLIENT_SECRET=replace_with_mal_client_secret
MAL_REDIRECT_URI=http://localhost:3000/api/mal/callback

# Media proxy host allowlist
MEDIA_PROXY_ALLOWED_HOSTS=animethemes.moe,*.animethemes.moe

# Optional tuning (safe to omit)
# NODE_ENV=production
# MEDIA_PROXY_ENABLED=true
# MEDIA_PROXY_PATH=/api/game/media/proxy
# MEDIA_PROXY_SIGNING_SECRET=replace_with_long_random_proxy_secret
# MEDIA_PROXY_URL_TTL_SEC=900
# MEDIA_PROXY_FETCH_TIMEOUT_MS=20000
# MEDIA_PROXY_RATE_LIMIT_WINDOW_MS=60000
# MEDIA_PROXY_RATE_LIMIT_MAX=60
# MEDIA_PROXY_LAST_USED_TOUCH_INTERVAL_MS=60000
# MEDIA_PROXY_CACHE_DIR=../.cache/media
# MEDIA_PROXY_CACHE_MAX_BYTES=5368709120
# LOBBY_IDLE_TIMEOUT_MS=600000
# LOBBY_CLEANUP_INTERVAL_MS=60000
# CLEANUP_SWEEP_INTERVAL_MS=60000
# SESSION_STALE_IN_PROGRESS_MS=5400000
# SESSION_RETENTION_MS=86400000
# RATE_LIMIT_GRACE_MS=300000
# ANIME_CATALOG_SYNC_INTERVAL_MS=86400000
# ANIME_CATALOG_SYNC_STARTUP_PAGES=8
# JIKAN_BASE_URL=https://api.jikan.moe/v4
# JIKAN_SEARCH_TIMEOUT_MS=8000
# JIKAN_SEARCH_CACHE_TTL_MS=300000
# JIKAN_SEARCH_CACHE_MAX_ENTRIES=500
# JIKAN_CATALOG_SYNC_PAGE_SIZE=25
# JIKAN_CATALOG_SYNC_PAGES_PER_RUN=20
# JIKAN_CATALOG_SYNC_DELAY_MS=250
# JIKAN_CATALOG_SYNC_RETRY_ATTEMPTS=6
# JIKAN_CATALOG_SYNC_RETRY_BASE_DELAY_MS=1500
# MAL_API_BASE_URL=https://api.myanimelist.net/v2
# MAL_WATCHED_PAGE_SIZE=100
# MAL_WATCHED_MAX_PAGES=20
# MAL_WATCHED_CACHE_TTL_MS=300000
# MAL_WATCHED_CACHE_MAX_USERS=500
# TELEMETRY_LEVEL=info
# TELEMETRY_ENABLED=true
