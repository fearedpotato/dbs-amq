# Copy this file to `.env` and replace placeholder values.
# PowerShell: Copy-Item .env.example .env

# App
BASE_URL=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/animeapp
PORT=3000

# Security (must be >= 16 chars)
JWT_SECRET=replace_with_long_random_jwt_secret
SESSION_SECRET=replace_with_long_random_session_secret
LOBBY_INVITE_SECRET=replace_with_long_random_lobby_invite_secret
TOKEN_ENCRYPTION_KEY=replace_with_long_random_token_encryption_key

# Email (for verify/reset flows)
EMAIL_USER=you@example.com
EMAIL_PASS=replace_with_email_app_password

# MyAnimeList OAuth
MAL_CLIENT_ID=replace_with_mal_client_id
MAL_CLIENT_SECRET=replace_with_mal_client_secret
MAL_REDIRECT_URI=http://localhost:3000/api/mal/callback

# Media proxy host allowlist
MEDIA_PROXY_ALLOWED_HOSTS=animethemes.moe,*.animethemes.moe

# Optional tuning (safe to omit)
# NODE_ENV=development
# MEDIA_PROXY_ENABLED=true
# TELEMETRY_LEVEL=info
